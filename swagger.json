  "definitions": {
    "Student": {
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string",
          "example": "Miracle"
        },
        "lastName": {
          "type": "string",
          "example": "Lawrence"
        },
        "age": {
          "type": "number",
          "example": 25
        },
        "email": {
          "type": "string",
          "example": "test@gmail.com"
        },
        "course": {
          "type": "string",
          "example": "Software Dev"
        },
        "level": {
          "type": "string",
          "example": "400"
        },
        "gender": {
          "type": "string",
          "example": "Male"
        },
        "cgpa": {
          "type": "number",
          "example": 4.5
        }
      }
    },
    "Course": {
      "type": "object",
      "properties": {
        "courseName": {
          "type": "string",
          "example": "Web Development"
        },
        "courseCode": {
          "type": "string",
          "example": "CSC401"
        },
        "instructor": {
          "type": "string",
          "example": "Dr John"
        },
        "units": {
          "type": "number",
          "example": 3
        },
        "department": {
          "type": "string",
          "example": "Computer Science"
        },
        "semester": {
          "type": "string",
          "example": "First Semester"
        },
        "level": {
          "type": "string",
          "example": "400"
        }
      }
    }
  }
